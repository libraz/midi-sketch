{
  "name": "@libraz/midi-sketch",
  "version": "0.2.0",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "description": "MIDI auto-generation library for pop music sketches",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "npx only-allow yarn",
    "postinstall": "simple-git-hooks",
    "prepare": "simple-git-hooks",
    "build": "yarn build:wasm && yarn build:js",
    "build:wasm": "cmake -E remove -f build-wasm/CMakeCache.txt && cmake -E remove_directory build-wasm/CMakeFiles && emcmake cmake -B build-wasm -DBUILD_WASM=ON && cmake --build build-wasm",
    "build:js": "node scripts/build-js.mjs",
    "clean": "rm -rf dist",
    "lint": "biome check js/ tests/wasm/",
    "lint:fix": "biome check --write js/ tests/wasm/",
    "format": "biome format --write js/ tests/wasm/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "yarn lint && yarn build"
  },
  "keywords": [
    "midi",
    "music",
    "generator",
    "pop",
    "wasm",
    "webassembly"
  ],
  "author": "libraz <libraz@libraz.net>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/libraz/midi-sketch.git"
  },
  "bugs": {
    "url": "https://github.com/libraz/midi-sketch/issues"
  },
  "homepage": "https://github.com/libraz/midi-sketch#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "esbuild": "^0.28.0",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "volta": {
    "node": "22.22.3",
    "yarn": "4.12.0"
  },
  "simple-git-hooks": {
    "pre-commit": "yarn lint-staged"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "biome check --write"
    ]
  }
}
